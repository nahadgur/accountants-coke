# Public — safe to expose to the browser
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only — NEVER expose. Bypasses RLS. Used by billing webhook + route_lead.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Public site URL (used for auth email redirects + OG metadata)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Paystack (server-only) — used to verify webhook signatures + create subscriptions
PAYSTACK_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_xxx
